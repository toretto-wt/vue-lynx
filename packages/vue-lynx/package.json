{
  "name": "vue-lynx",
  "version": "0.3.1",
  "private": false,
  "description": "Vue 2.7 framework for building Lynx apps",
  "keywords": [
    "vue",
    "lynx",
    "vue-lynx",
    "renderer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Huxpro/vue-lynx.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./runtime/dist/index.d.ts",
      "import": "./runtime/dist/index.js",
      "default": "./runtime/dist/index.js"
    },
    "./entry-background": {
      "types": "./runtime/dist/entry-background.d.ts",
      "import": "./runtime/dist/entry-background.js",
      "default": "./runtime/dist/entry-background.js"
    },
    "./plugin": {
      "types": "./plugin/dist/index.d.ts",
      "import": "./plugin/dist/index.js",
      "default": "./plugin/dist/index.js"
    },
    "./main-thread": {
      "types": "./main-thread/dist/entry-main.d.ts",
      "import": "./main-thread/dist/entry-main.js",
      "default": "./main-thread/dist/entry-main.js"
    },
    "./internal/ops": {
      "types": "./internal/dist/ops.d.ts",
      "import": "./internal/dist/ops.js",
      "default": "./internal/dist/ops.js"
    },
    "./types": {
      "types": "./types/dist/index.d.ts",
      "import": "./types/dist/index.js",
      "default": "./types/dist/index.js"
    },
    "./types/volar-plugin": {
      "import": "./types/dist/volar-plugin.cjs",
      "default": "./types/dist/volar-plugin.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./runtime/dist/index.js",
  "types": "./runtime/dist/index.d.ts",
  "files": [
    "runtime/dist",
    "main-thread/dist",
    "plugin/dist",
    "internal/dist",
    "types/dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "(cd internal && npx tsc -p tsconfig.build.json) && (cd runtime && npx rslib build) && (cd main-thread && npx rslib build) && (cd plugin && npx rslib build) && (cd types && npx rslib build)",
    "dev": "(cd internal && npx tsc -p tsconfig.build.json) && (cd runtime && npx rslib build --watch) & (cd main-thread && npx rslib build --watch) & (cd plugin && npx rslib build --watch) & (cd types && npx rslib build --watch)"
  },
  "dependencies": {
    "@lynx-js/css-extract-webpack-plugin": "^0.7.0",
    "@lynx-js/react": "^0.116.5",
    "@lynx-js/runtime-wrapper-webpack-plugin": "^0.1.3",
    "@lynx-js/template-webpack-plugin": "^0.10.5",
    "@lynx-js/webpack-dev-transport": "^0.2.0",
    "vue": "^2.7.16"
  },
  "devDependencies": {
    "@lynx-js/type-element-api": "0.0.3",
    "@lynx-js/types": "3.7.0",
    "@rsbuild/plugin-vue2": "^1.1.1",
    "@rslib/core": "^0.7.0",
    "@types/node": "^25.5.0",
    "rsbuild-plugin-publint": "0.3.4",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0",
    "@rsbuild/plugin-vue2": "^1.1.1"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": false
    },
    "@rsbuild/plugin-vue2": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=18"
  }
}
